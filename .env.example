# Copy to `.env` (read by docker-compose). Never commit the real `.env`.

# ── Public URLs (baked into the web build) ──────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://portretdoorjosette.nl
NEXT_PUBLIC_POCKETBASE_URL=https://cms.portretdoorjosette.nl

# ── Revalidation: shared secret between the PocketBase hook and the Next app ─
# Generate one, e.g.:  openssl rand -hex 32
REVALIDATE_SECRET=change-me-to-a-long-random-string

# ── Contact form (Resend) ───────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
CONTACT_TO_EMAIL=info@portretdoorjosette.nl
# Must be an address on a domain verified in Resend once DNS is set up.
CONTACT_FROM_EMAIL=Portret door Josette <website@portretdoorjosette.nl>

# ── PocketBase release to build (schema verified against 0.39.5) ────────────
# https://github.com/pocketbase/pocketbase/releases
PB_VERSION=0.39.5

# ── Optional socials (shown on Contact + used in JSON-LD sameAs) ─────────────
NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/profile.php?id=61560156520268
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/josettespapens16

# ── Optional: Google Search Console meta-tag verification (baked at build) ────
# Only needed if you verify via the HTML tag; DNS (TXT record) verification
# needs nothing here. Paste just the token from the meta tag's content.
GOOGLE_SITE_VERIFICATION=
